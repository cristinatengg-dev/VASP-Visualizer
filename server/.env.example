# Runtime / backend deployment example
# Copy to server/.env when you run the backend with:
#   cd server && npm start

# Prefer a dedicated runtime URI when you want runtime data separated
# from any legacy Mongo usage.
RUNTIME_MONGODB_URI=mongodb://127.0.0.1:27017/vasp_visualizer

# Runtime demo / workers
ENABLE_AGENT_RUNTIME_DEMO=1
ENABLE_AGENT_RUNTIME_WORKERS=1

# Rendering
GEMINI_API_KEY=
GEMINI_BASE_URL=https://api.aipaibox.com/v1
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Modeling
MODELING_PYTHON_EXECUTABLE=/absolute/path/to/server/.venv-modeling/bin/python
MP_API_KEY=
ATOMLY_OPTIMADE_BASE_URL=
ATOMLY_CIF_DIR=
CSD_CIF_DIR=
CSD_PYTHON_API=0
ICSD_OPTIMADE_BASE_URL=
ICSD_CIF_DIR=

# Compute: run directly on the same server that hosts this backend
COMPUTE_LOCAL_COMMAND="mpirun -np 8 vasp_std"
COMPUTE_LOCAL_SHELL=/bin/zsh
COMPUTE_LOCAL_RUNNER_ID=server-local

# Pseudopotentials
VASP_PSP_DIR=/absolute/path/to/potpaw_PBE
# Alternative names also supported by the runtime:
# VASP_POTCAR_DIR=/absolute/path/to/potpaw_PBE
# POTCAR_LIBRARY_DIR=/absolute/path/to/potpaw_PBE

# Optional runtime storage overrides
RUNTIME_ARTIFACT_STORAGE_DIR=/absolute/path/to/runtime-storage/artifacts
RUNTIME_JOB_STORAGE_DIR=/absolute/path/to/runtime-storage/jobs

# Worker tuning
RUNTIME_APPROVAL_SWEEPER_INTERVAL_MS=60000
RUNTIME_JOB_MONITOR_INTERVAL_MS=15000
RUNTIME_HARVEST_LAG_MONITOR_INTERVAL_MS=120000

# Optional Slurm profile
HPC_SLURM_PARTITION=
HPC_EXECUTABLE=
HPC_SCHEDULER_REF=slurm-default
HPC_NODES=1
HPC_TASKS_PER_NODE=32
HPC_WALLTIME=12:00:00
HPC_MODULE_LOAD=

# Optional PBS profile
HPC_PBS_QUEUE=

# Optional: queue PBS jobs for an external local compute agent
COMPUTE_AGENT_TOKEN=
COMPUTE_AGENT_SCHEDULER_REF=pbs-agent
COMPUTE_AGENT_BASE_URL=
COMPUTE_AGENT_EXECUTION_PROFILE=pbs_default
COMPUTE_AGENT_POLL_INTERVAL_MS=15000

# Optional: submit/query Slurm over SSH instead of requiring local sbatch/squeue
HPC_SSH_HOST=
HPC_SSH_PORT=22
HPC_SSH_USER=
HPC_SSH_KEY_PATH=
HPC_REMOTE_BASE_DIR=
HPC_REMOTE_POTCAR_DIR=
HPC_REMOTE_SHELL=/bin/bash
HPC_REMOTE_PRELUDE=
